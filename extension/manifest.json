{
  "manifest_version": 3,
  "name": "Tab Out",
  "version": "1.0.0",
  "description": "掌控你的标签页。新标签页按域名分组显示已打开的标签页,让你优雅地关闭它们。",
  "permissions": ["tabs", "activeTab", "storage"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
